# Copy to .env and fill in. .env is gitignored.

# Required for AI features (JD parsing, resume tailoring, cover letter).
ANTHROPIC_API_KEY=

# Single-user API key. If empty, auth is disabled (dev only).
# Recommended: generate with `openssl rand -hex 32`.
API_KEY=

# Optional overrides.
CLAUDE_MODEL=claude-sonnet-4-6
DATABASE_URL=sqlite:////data/app.db
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:8080
